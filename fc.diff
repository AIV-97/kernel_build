--- arch/arm64/boot/dts/vendor/qcom/pmic632.dtsi
+++ arch/arm64/boot/dts/vendor/qcom/pmic632.dtsi
@@ -34,6 +34,12 @@
 	interrupts = <0 103 0>;
 	#address-cells = <1>;
 	#size-cells = <0>;
 
 	pmic-voter {
 		compatible = "qcom,pmic-voter";
 	};
 
+	/* Disable JEITA (Japan Electronics and Information Technology Industries Association) */
+	qcom,disable-jeita = <1>;
+	/* Bypass JEITA temperature regulation for charging */
+	qcom,jeita-bypass = <1>;
+	
 	pmi632_charger: qcom,qpnp-smb5 {
 		compatible = "qcom,qpnp-smb5";
 		reg = <0x68>;
 		interrupts = <0 58 0>;
 		...
+	};
 
+	/* Enable charging above JEITA recommended limits */
+	charge_limit {
+		qcom,jeita-override = <1>;
+	};
 
 };
